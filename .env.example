# ============================================================================
# PUUTARHAKANTA API Configuration
# ============================================================================

# DATABASE CONFIGURATION
# ============================================================================
# For SQLite (default): No database variables needed!
# The app will automatically use: ./sqlite-backup/puutarhakanta2005.sqlite
#
# For MySQL: Uncomment and set these variables

# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=puutarhakanta2005
# DB_USER=your_user
# DB_PASSWORD=your_password

# Optional: Full SQLAlchemy connection URL (overrides above)
# Useful for custom database setups or non-standard ports
# DATABASE_URL=mysql+pymysql://user:password@host:3306/database
# DATABASE_URL=sqlite:///./sqlite-backup/puutarhakanta2005.sqlite

# AUTHENTICATION
# ============================================================================
# JWT secret key for signing authentication tokens
# IMPORTANT: Use a strong random string (min 32 characters)
SECRET_KEY=your-secret-key-minimum-32-characters-long-for-jwt-signing

# JWT algorithm (usually HS256)
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15
