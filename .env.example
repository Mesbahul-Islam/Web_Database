# ============================================================================
# PUUTARHAKANTA API Configuration
# ============================================================================

# DATABASE CONFIGURATION
# ============================================================================
# The application reads a single database setting at runtime: DATABASE_URL.
# Use a SQLAlchemy-compatible connection string for PostgreSQL, Prisma Postgres,
# or another backend you want to connect to.

DATABASE_URL=postgresql+psycopg2://user:password@host:5432/postgres?sslmode=require

# AUTHENTICATION
# ============================================================================
# JWT secret key for signing authentication tokens
# IMPORTANT: Use a strong random string (min 32 characters)
SECRET_KEY=your-secret-key-minimum-32-characters-long-for-jwt-signing

# JWT algorithm (usually HS256)
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15
